# Secrets & local state — never publish these (config.yaml holds real API keys).
config.yaml
config.yaml.bak
config.yaml.tmp
.env
.env.local
dashboard/.env.local
data/
*.sqlite
*.sqlite-journal
*.log

# Build output + caches — the dashboard is (re)built on first run by the
# launcher's ensureSetup(), so we don't ship dashboard/.next (Next's nested
# .gitignore excludes it anyway).
dashboard/.next/
.claude/
.gstack/
tests/
*.test.ts
