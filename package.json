{
  "name": "aigetwey",
  "version": "1.4.1",
  "type": "module",
  "description": "Personal AI gateway — route, translate and track requests across Anthropic and OpenAI-compatible providers, with a built-in dashboard.",
  "keywords": [
    "ai",
    "gateway",
    "llm",
    "proxy",
    "anthropic",
    "openai",
    "router",
    "claude",
    "dashboard"
  ],
  "license": "MIT",
  "author": "xk1ko <221650117+xk1ko@users.noreply.github.com>",
  "homepage": "https://github.com/xk1ko/aigetwey#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xk1ko/aigetwey.git"
  },
  "bugs": {
    "url": "https://github.com/xk1ko/aigetwey/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "aigetwey": "dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "dashboard",
    "assets",
    "config.example.yaml",
    "tsconfig.json",
    "run.sh",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "run:all": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm --prefix dashboard run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.5.0",
    "fastify": "^5.2.0",
    "undici": "^7.2.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.21.5": true
  }
}
